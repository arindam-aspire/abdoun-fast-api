{
  "info": {
    "name": "Agency Registration API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register Agency",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{baseUrl}}/api/v1/agency/register",
        "body": {
          "mode": "formdata",
          "formdata": [
            {"key": "email", "value": "agency@example.com", "type": "text"},
            {"key": "phone_number", "value": "+962790000001", "type": "text"},
            {"key": "agency_name", "value": "Example Agency LLC", "type": "text"},
            {"key": "agency_trade_name", "value": "Example Agency", "type": "text"},
            {"key": "password", "value": "AgencyPass1!", "type": "text"},
            {"key": "legal_document", "type": "file", "src": ""},
            {"key": "address", "value": "", "type": "text", "disabled": true},
            {"key": "city", "value": "", "type": "text", "disabled": true},
            {"key": "state", "value": "", "type": "text", "disabled": true},
            {"key": "country", "value": "", "type": "text", "disabled": true},
            {"key": "zipcode", "value": "", "type": "text", "disabled": true},
            {"key": "website", "value": "", "type": "text", "disabled": true}
          ]
        }
      }
    },
    {
      "name": "Login Agency",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/api/v1/agency/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"agency@example.com\",\n  \"password\": \"AgencyPass1!\"\n}"
        }
      }
    },
    {
      "name": "List Agencies",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}],
        "url": "{{baseUrl}}/api/v1/agency/list"
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:8000"},
    {"key": "accessToken", "value": ""}
  ]
}
