# FastAPI Settings
APP_NAME="Abdoun Real Estate API"
DEBUG=False
API_V1_PREFIX="/api/v1"
ENVIRONMENT=local

# Database Settings
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:password@localhost:5432/abdoun_db"

# SQLAlchemy pool tuning (optional)
# These match defaults in app/core/config.py; override per environment as needed.
DB_POOL_SIZE="5"
DB_MAX_OVERFLOW="10"
DB_POOL_TIMEOUT="30"
DB_POOL_RECYCLE="1800"
DB_POOL_PRE_PING="true"

# ---------------------------------------------------------------------------
# AWS Cognito (required for auth: password, OTP, social login)
# ---------------------------------------------------------------------------
COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
COGNITO_APP_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_APP_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Backward-compatible aliases (optional):
# COGNITO_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
# COGNITO_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_REGION="us-east-1"
# Cognito domain (no https://). Used for Hosted UI and social login URLs.
COGNITO_DOMAIN="your-prefix.auth.us-east-1.amazoncognito.com"

# Social login (Google, Apple, etc.): must match a Callback URL in Cognito App client
# e.g. http://localhost:8000/api/v1/auth/callback or https://your-api.com/api/v1/auth/callback
SOCIAL_REDIRECT_URI="http://localhost:8000/api/v1/auth/callback"

# Self-service profile: phone OTP is app-hashed; email OTP uses Cognito CUSTOM_AUTH (same as login OTP).
# PROFILE_OTP_PEPPER: used to hash phone OTPs (set a long random value in production).
PROFILE_OTP_PEPPER="dev-only-change-profile-otp-pepper"
PROFILE_OTP_TTL_MINUTES=10
# When true, dev_phone_otp is omitted from profile responses (set after SMS is integrated).
PROFILE_OTP_HIDE_PHONE_CODE_IN_RESPONSE=false
# Remember Me server-side session duration in days (hard-capped at 30)
REMEMBER_ME_SESSION_DAYS=30

# Password login lockout (failed attempts within rolling window → temporary lock)
PASSWORD_LOGIN_MAX_FAILED_ATTEMPTS=5
PASSWORD_LOGIN_ROLLING_WINDOW_MINUTES=15
PASSWORD_LOGIN_LOCK_DURATION_MINUTES=15

# AWS credentials (optional)
# If omitted, boto3 will use IAM role / shared credentials chain instead.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT_URL=""
AWS_S3_PUBLIC_BASE_URL=""
AWS_S3_PRESIGNED_EXPIRY=900
# Presigned GET lifetime (seconds) for URLs returned in JSON when the bucket is private
AWS_S3_PRESIGNED_GET_EXPIRY=3600
AWS_S3_USE_PRESIGNED_URL=true

PROPERTY_VIDEO_RESOLUTION=""
PROPERTY_VIDEO_MIN_DURATION_SEC=
PROPERTY_VIDEO_MAX_DURATION_SEC=
PROPERTY_VIDEO_MAX_SIZE_MB=100
PROPERTY_VIDEO_CODEC=""
PROPERTY_VIDEO_AUTOPLAY=false
PROPERTY_VIDEO_MUTED=false
PROPERTY_VIDEO_LOOP=false

PROPERTY_IMAGE_MAX_SIZE_MB=20
PROPERTY_DOCUMENT_MAX_SIZE_MB=20

ALLOWED_PROPERTY_IMAGE_EXTENSIONS=".jpg,.jpeg,.png,.webp"
ALLOWED_PROPERTY_DOCUMENT_EXTENSIONS=".pdf,.doc,.docx"
ALLOWED_PROPERTY_VIDEO_EXTENSIONS=".mp4,.mov,.avi,.mkv,.webm"

# Server-side watermarking for POST /uploads/property-images (property photos only)
WATERMARK_IMAGE_PATH=app/assets/watermark/abdoun_water_mark_logo.png
WATERMARK_SCALE=0.50
WATERMARK_OPACITY=128
WATERMARK_POSITION=center
WATERMARK_POLL_INTERVAL_SECONDS=2
WATERMARK_POLL_TIMEOUT_SECONDS=300
POSITION_PADDING=20
JPEG_QUALITY=95

# ---------------------------------------------------------------------------
# App & CORS (frontend URL, invite links, allowed origins)
# ---------------------------------------------------------------------------
# Base URL of your frontend (e.g. for agent invite links)
APP_BASE_URL="http://localhost:3000"
# Comma-separated origins allowed by CORS (browser requests). Must match the browser URL exactly:
# "localhost" and "127.0.0.1" are different origins — list both if you use both. Missing entries
# cause OPTIONS preflight → 400 before POST runs. Override in production with real FE URLs only.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081,http://127.0.0.1:8081"

# Advanced CORS controls (optional)
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Authorization,Content-Type,Accept,Origin,X-Requested-With,X-Request-ID"

# ---------------------------------------------------------------------------
# Observability (all optional; disabled unless enabled below)
# ---------------------------------------------------------------------------
# Metrics (Prometheus)
METRICS_ENABLED="false"
METRICS_PATH="/metrics"

# OpenTelemetry tracing
OTEL_ENABLED="false"
OTEL_SERVICE_NAME=""

# Sentry error reporting
SENTRY_ENABLED="false"
SENTRY_DSN=""

# DB slow query logging threshold (milliseconds)
SLOW_QUERY_THRESHOLD_MS="200"

# Dashboard summary scheduler
# Executes one refresh per day at the configured local server time (HH:MM, 24h).
DASHBOARD_SUMMARY_SCHEDULER_ENABLED="true"
DASHBOARD_SUMMARY_SCHEDULE_TIME="00:10"

# ---------------------------------------------------------------------------
# Optional: Azure OpenAI for Geocoding Fallback
# ---------------------------------------------------------------------------
AZURE_OPENAI_KEY="your-key"
AZURE_ENDPOINT="your-endpoint"
AZURE_API_VERSION="2023-05-15"
AZURE_DEPLOYMENT_NAME="gpt-35-turbo"
