# FastAPI Settings
APP_NAME="Abdoun Real Estate API"
DEBUG=False
API_V1_PREFIX="/api/v1"
ENVIRONMENT=local

# Database Settings
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:password@localhost:5432/abdoun_db"

# SQLAlchemy pool tuning (optional)
# These match defaults in app/core/config.py; override per environment as needed.
DB_POOL_SIZE="5"
DB_MAX_OVERFLOW="10"
DB_POOL_TIMEOUT="30"
DB_POOL_RECYCLE="1800"
DB_POOL_PRE_PING="true"

# ---------------------------------------------------------------------------
# AWS Cognito (required for auth: password, OTP, social login)
# ---------------------------------------------------------------------------
COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
COGNITO_APP_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_APP_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Backward-compatible aliases (optional):
# COGNITO_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
# COGNITO_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_REGION="us-east-1"
# Cognito domain (no https://). Used for Hosted UI and social login URLs.
COGNITO_DOMAIN="your-prefix.auth.us-east-1.amazoncognito.com"

# Social login (Google, Apple, etc.): must match a Callback URL in Cognito App client
# e.g. http://localhost:8000/api/v1/auth/callback or https://your-api.com/api/v1/auth/callback
SOCIAL_REDIRECT_URI="http://localhost:8000/api/v1/auth/callback"

# AWS credentials (optional)
# If omitted, boto3 will use IAM role / shared credentials chain instead.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ---------------------------------------------------------------------------
# App & CORS (frontend URL, invite links, allowed origins)
# ---------------------------------------------------------------------------
# Base URL of your frontend (e.g. for agent invite links)
APP_BASE_URL="http://localhost:3000"
# Comma-separated origins allowed by CORS (browser requests)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Advanced CORS controls (optional)
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Authorization,Content-Type,X-Request-ID"

# ---------------------------------------------------------------------------
# Observability (all optional; disabled unless enabled below)
# ---------------------------------------------------------------------------
# Metrics (Prometheus)
METRICS_ENABLED="false"
METRICS_PATH="/metrics"

# OpenTelemetry tracing
OTEL_ENABLED="false"
OTEL_SERVICE_NAME=""

# Sentry error reporting
SENTRY_ENABLED="false"
SENTRY_DSN=""

# DB slow query logging threshold (milliseconds)
SLOW_QUERY_THRESHOLD_MS="200"

# Dashboard summary scheduler
# Executes one refresh per day at the configured local server time (HH:MM, 24h).
DASHBOARD_SUMMARY_SCHEDULER_ENABLED="true"
DASHBOARD_SUMMARY_SCHEDULE_TIME="00:10"

# ---------------------------------------------------------------------------
# Optional: Azure OpenAI for Geocoding Fallback
# ---------------------------------------------------------------------------
AZURE_OPENAI_KEY="your-key"
AZURE_ENDPOINT="your-endpoint"
AZURE_API_VERSION="2023-05-15"
AZURE_DEPLOYMENT_NAME="gpt-35-turbo"
