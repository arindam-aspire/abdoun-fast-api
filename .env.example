# FastAPI Settings
APP_NAME="Abdoun Real Estate API"
DEBUG=False
API_V1_PREFIX="/api/v1"
ENVIRONMENT=local

# Database Settings
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:password@localhost:5432/abdoun_db"

# ---------------------------------------------------------------------------
# AWS Cognito (required for auth: password, OTP, social login)
# ---------------------------------------------------------------------------
COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
COGNITO_APP_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_APP_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Backward-compatible aliases (optional):
# COGNITO_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
# COGNITO_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
COGNITO_REGION="us-east-1"
# Cognito domain (no https://). Used for Hosted UI and social login URLs.
COGNITO_DOMAIN="your-prefix.auth.us-east-1.amazoncognito.com"

# Social login (Google, Apple, etc.): must match a Callback URL in Cognito App client
# e.g. http://localhost:8000/api/v1/auth/callback or https://your-api.com/api/v1/auth/callback
SOCIAL_REDIRECT_URI="http://localhost:8000/api/v1/auth/callback"

# ---------------------------------------------------------------------------
# App & CORS (frontend URL, invite links, allowed origins)
# ---------------------------------------------------------------------------
# Base URL of your frontend (e.g. for agent invite links)
APP_BASE_URL="http://localhost:3000"
# Comma-separated origins allowed by CORS (browser requests)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ---------------------------------------------------------------------------
# Optional: Azure OpenAI for Geocoding Fallback
# ---------------------------------------------------------------------------
AZURE_OPENAI_KEY="your-key"
AZURE_ENDPOINT="your-endpoint"
AZURE_API_VERSION="2023-05-15"
AZURE_DEPLOYMENT_NAME="gpt-35-turbo"
